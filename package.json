{
  "name": "reservation_backend",
  "version": "1.0.0",
  "description": "The service of reservation project for coding factory 8.",
  "homepage": "https://github.com/anstkostas/reservation_backend#readme",
  "bugs": {
    "url": "https://github.com/anstkostas/reservation_backend/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anstkostas/reservation_backend.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/server.js",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src",
    "test": "NODE_ENV=test vitest run",
    "dev:test": "NODE_ENV=test tsx watch src/server.ts",
    "test:watch": "NODE_ENV=test vitest",
    "test:coverage": "NODE_ENV=test vitest run --coverage",
    "test:migrate": "tsx prisma/test-migrate.ts",
    "docker:up": "docker compose -f ../docker-compose.yml up -d postgres",
    "docker:up:full": "docker compose -f ../docker-compose.yml up -d",
    "docker:down": "docker compose -f ../docker-compose.yml down",
    "docker:logs": "docker compose -f ../docker-compose.yml logs -f",
    "docker:rebuild": "docker compose -f ../docker-compose.yml build backend && docker compose -f ../docker-compose.yml restart backend",
    "db:migrate": "prisma migrate dev && (npm run test:migrate || (echo '' && echo '⚠️  Test DB sync skipped — test DB may not be running.' && echo '   Start:    sudo -u postgres /Library/PostgreSQL/18/bin/pg_ctl start -D /Library/PostgreSQL/18/data' && echo '   Then run: npm run test:migrate'))",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "pg": "^8.21.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.5"
  }
}
